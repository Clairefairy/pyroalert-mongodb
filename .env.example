# MongoDB Atlas connection string (replace placeholders):
MONGODB_URI=mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/pyroalert?retryWrites=true&w=majority
# Example (replace placeholders):
# mongodb+srv://admin:MyP@ssw0rd@cluster0.abcd1.mongodb.net/pyroalert?retryWrites=true&w=majority

PORT=4000
JWT_SECRET=replace_with_a_strong_secret
JWT_EXPIRES_IN=900s
BCRYPT_SALT_ROUNDS=10

# Adafruit IO
# Use a chave da conta para feeds privados (X-AIO-Key)
ADAFRUIT_IO_KEY=replace_with_your_adafruit_aio_key
# Habilita sincronização automática para o MongoDB
ADAFRUIT_AUTO_SYNC=true
# Intervalo de sincronização em milissegundos (mínimo recomendado: 5000)
ADAFRUIT_SYNC_INTERVAL_MS=30000
# IDs de dispositivo separados por vírgula (opcional). Se vazio, sincroniza todos do banco.
# ADAFRUIT_SYNC_DEVICE_IDS=PYRO-TEST-001,PYRO-001
